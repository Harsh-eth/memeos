# Production: set to your API origin, e.g. https://api.example.com
VITE_API_BASE_URL=http://localhost:8080

# Must match backend MEMEOS_CLIENT_TOKEN (sent only from this app on generate)
VITE_MEMEOS_CLIENT_TOKEN=

# Must match backend MEMEOS_HMAC_SECRET — used to sign generate requests in the browser
VITE_MEMEOS_HMAC_SECRET=

# Optional: repo link for header "github"
VITE_GITHUB_URL=https://github.com
