REDIS_URL=redis://localhost:6379

# Optional: without this key, planner/caption use deterministic mock output.
OPENAI_API_KEY=

# Model for planner + caption (JSON + text)
OPENAI_MODEL=gpt-4o-mini

# Background auto-meme interval (seconds)
AUTO_INTERVAL_SECONDS=45

# Comma-separated origins for CORS + generate Origin/Referer allowlist
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# —— Generate endpoint security (required for POST /generate-meme) ——
# Must match frontend VITE_MEMEOS_CLIENT_TOKEN exactly. Empty = generate returns 503.
MEMEOS_CLIENT_TOKEN=change-me

# HMAC-SHA256 secret for signed generate body (must match VITE_MEMEOS_HMAC_SECRET). Empty = 503.
MEMEOS_HMAC_SECRET=change-me

# Claude API key (optional; included for deployments that use Claude)
CLAUDE_API_KEY=your_key

# Max generations per server calendar day across all clients (503 when exceeded)
MAX_DAILY_GENERATIONS_GLOBAL=500

# Min seconds between generate requests from the same IP
BURST_INTERVAL_SECONDS=3

# Max seconds for caption + render in the generate worker (504 on exceed)
GENERATE_TIMEOUT_SECONDS=10

# Optional: directory for PNG cache (default backend/data/image_cache)
IMAGE_CACHE_DIR=

# Fixed output size after render (no client override)
MEME_OUTPUT_WIDTH=560
MEME_OUTPUT_HEIGHT=360

# Max successful generations per IP per calendar day (server local date)
GENERATE_MAX_PER_IP_PER_DAY=5

# Behind nginx/caddy with X-Forwarded-For? Set true only if you trust the proxy.
TRUST_PROXY_FOR_IP=false

# Comma-separated IPs that skip the daily cap (local dev only; empty in production)
RATE_LIMIT_EXEMPT_IPS=

# Stricter browser-only: Sec-Fetch-Site must be same-origin or same-site
REQUIRE_SEC_FETCH_SITE_BROWSER=false

BLOCK_EMPTY_USER_AGENT=true
MIN_USER_AGENT_LENGTH=8
BLOCK_CLI_USER_AGENTS=true
REQUIRE_JSON_CONTENT_TYPE=true
REQUIRE_ORIGIN_OR_REFERER=true
